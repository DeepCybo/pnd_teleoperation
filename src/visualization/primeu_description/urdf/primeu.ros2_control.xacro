<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="primeu_ros2_control" params="name">

    <ros2_control name="${name}" type="system">
      <hardware>
        <plugin>primeu_hardware/HybridSystemInterface</plugin>
        <param name="can_interface">can0</param>
      </hardware>

      <!-- Left arm EtherCAT joints (joint_11..joint_15) -->
      <joint name="arm_left_shoulder_pitch_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <joint name="arm_left_shoulder_roll_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <joint name="arm_left_shoulder_yaw_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <joint name="arm_left_elbow_pitch_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <joint name="arm_left_wrist_yaw_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- Left arm CAN wrist (0x16/0x17) -->
      <joint name="arm_left_wrist_roll_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
        <param name="can_id">22</param> <!-- 0x16 -->
      </joint>

      <joint name="arm_left_wrist_pitch_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
        <param name="can_id">23</param> <!-- 0x17 -->
      </joint>

      <!-- Right arm EtherCAT joints (joint_21..joint_25) -->
      <joint name="arm_right_shoulder_pitch_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <joint name="arm_right_shoulder_roll_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <joint name="arm_right_shoulder_yaw_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <joint name="arm_right_elbow_pitch_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <joint name="arm_right_wrist_yaw_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- Right arm CAN wrist (0x26/0x27) -->
      <joint name="arm_right_wrist_roll_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
        <param name="can_id">38</param> <!-- 0x26 -->
      </joint>

      <joint name="arm_right_wrist_pitch_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
        <param name="can_id">39</param> <!-- 0x27 -->
      </joint>

    </ros2_control>

  </xacro:macro>

</robot>
