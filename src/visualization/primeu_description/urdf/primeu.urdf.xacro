<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="primeu_arm">
  
  <!-- Import ros2_control description -->
  <xacro:include filename="$(find primeu_description)/urdf/primeu.ros2_control.xacro" />

  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.1" radius="0.1"/>
      </geometry>
    </visual>
  </link>

  <!-- Joint 11 (EtherCAT) -->
  <joint name="joint_11" type="revolute">
    <parent link="base_link"/>
    <child link="link_11"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="10"/>
  </joint>
  <link name="link_11">
    <visual>
      <geometry>
        <cylinder length="0.1" radius="0.05"/>
      </geometry>
    </visual>
  </link>

  <!-- Joint 12 (EtherCAT) -->
  <joint name="joint_12" type="revolute">
    <parent link="link_11"/>
    <child link="link_12"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="10"/>
  </joint>
  <link name="link_12">
    <visual>
      <geometry>
        <cylinder length="0.1" radius="0.05"/>
      </geometry>
    </visual>
  </link>

  <!-- Joint 13 (EtherCAT) -->
  <joint name="joint_13" type="revolute">
    <parent link="link_12"/>
    <child link="link_13"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="10"/>
