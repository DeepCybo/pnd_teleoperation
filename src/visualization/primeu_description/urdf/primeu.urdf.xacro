  <link name="link_13">
    <visual>
      <geometry>
        <cylinder length="0.1" radius="0.05"/>
      </geometry>
    </visual>
  </link>

  <!-- Joint 14 (EtherCAT) -->
  <joint name="joint_14" type="revolute">
