<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="primeu_hybrid_ros2_control" params="name">

    <!-- ================================================================== -->
    <!-- 快速配置开关：true 为真实硬件，false 为虚拟硬件                      -->
    <!-- ================================================================== -->
    <xacro:arg name="use_mock_all" default="false"/> <!-- 一键全仿真开关 -->

    <!-- 左臂 EtherCAT (Pos 1-5) -->
    <xacro:arg name="real_l_arm" default="true"/>
    <!-- 右臂 EtherCAT (Pos 6-10) -->
    <xacro:arg name="real_r_arm" default="true"/>
    <!-- 左腕 CAN (ID 22, 23) -->
    <xacro:arg name="real_l_wrist" default="true"/>
    <!-- 右腕 CAN (ID 38, 39) -->
    <xacro:arg name="real_r_wrist" default="true"/>

    <!-- 内部逻辑变量 -->
    <xacro:property name="l_arm_enabled" value="$(arg real_l_arm)"/>
    <xacro:property name="r_arm_enabled" value="$(arg real_r_arm)"/>
    <xacro:property name="l_wrist_enabled" value="$(arg real_l_wrist)"/>
    <xacro:property name="r_wrist_enabled" value="$(arg real_r_wrist)"/>

    <xacro:if value="$(arg use_mock_all)">
      <xacro:property name="l_arm_enabled" value="false"/>
      <xacro:property name="r_arm_enabled" value="false"/>
      <xacro:property name="l_wrist_enabled" value="false"/>
      <xacro:property name="r_wrist_enabled" value="false"/>
    </xacro:if>

    <!-- 定义 EtherCAT 关节宏 -->
    <xacro:macro name="ec_joint" params="joint_name pos">
      <joint name="${joint_name}">
        <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
        <command_interface name="position"/>
        <command_interface name="effort"/>
        <command_interface name="reset_fault"/>
        <ec_module name="Slave${pos}">
          <plugin>ethercat_generic_plugins/EcCiA402Drive</plugin>
          <param name="alias">0</param>
          <param name="position">${pos}</param>
          <param name="slave_config">$(find primeu_description)/config/zeroErr.yaml</param>
        </ec_module>
      </joint>
    </xacro:macro>

    <!-- ================================================================== -->
    <!-- EtherCAT System: 10 joints (ZeroErr Motors)                        -->
    <!-- ================================================================== -->
    <xacro:if value="${l_arm_enabled or r_arm_enabled}">
      <ros2_control name="${name}_ethercat" type="system">
        <hardware>
          <plugin>ethercat_driver/EthercatDriver</plugin>
          <param name="master_id">0</param>
          <param name="control_frequency">1000</param>
        </hardware>

        <!-- 左臂关节 (1-5) -->
        <xacro:if value="${l_arm_enabled}">
          <xacro:ec_joint joint_name="arm_left_shoulder_pitch_joint" pos="1"/>
          <xacro:ec_joint joint_name="arm_left_shoulder_roll_joint" pos="2"/>
          <xacro:ec_joint joint_name="arm_left_shoulder_yaw_joint" pos="3"/>
          <xacro:ec_joint joint_name="arm_left_elbow_pitch_joint" pos="4"/>
          <xacro:ec_joint joint_name="arm_left_wrist_yaw_joint" pos="5"/>
        </xacro:if>

        <!-- 右臂关节 (6-10) -->
        <xacro:if value="${r_arm_enabled}">
          <xacro:ec_joint joint_name="arm_right_shoulder_pitch_joint" pos="6"/>
          <xacro:ec_joint joint_name="arm_right_shoulder_roll_joint" pos="7"/>
          <xacro:ec_joint joint_name="arm_right_shoulder_yaw_joint" pos="8"/>
          <xacro:ec_joint joint_name="arm_right_elbow_pitch_joint" pos="9"/>
          <xacro:ec_joint joint_name="arm_right_wrist_yaw_joint" pos="10"/>
        </xacro:if>
      </ros2_control>
    </xacro:if>

    <!-- ================================================================== -->
    <!-- CAN System: 4 Xintuo Wrist Motors                                  -->
    <!-- ================================================================== -->
    <xacro:macro name="can_joint" params="joint_name id">
      <joint name="${joint_name}">
        <command_interface name="position"/>
        <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
        <param name="can_id">${id}</param>
        <param name="encoder_resolution">65536</param>
        <param name="gear_ratio">101.0</param>
      </joint>
    </xacro:macro>

    <!-- Left Wrist CAN (can0) -->
    <xacro:if value="${l_wrist_enabled}">
      <ros2_control name="${name}_can_left" type="system">
        <hardware>
          <plugin>primeu_hardware/CanSystemInterface</plugin>
          <param name="can_interface">can0</param>
          <param name="is_async">true</param>
          <param name="thread_priority">50</param>
        </hardware>
        <xacro:can_joint joint_name="arm_left_wrist_roll_joint" id="16"/>
        <xacro:can_joint joint_name="arm_left_wrist_pitch_joint" id="17"/>
      </ros2_control>
    </xacro:if>

    <!-- Right Wrist CAN (can1) -->
    <xacro:if value="${r_wrist_enabled}">
      <ros2_control name="${name}_can_right" type="system">
        <hardware>
          <plugin>primeu_hardware/CanSystemInterface</plugin>
          <param name="can_interface">can1</param>
          <param name="is_async">true</param>
          <param name="thread_priority">50</param>
        </hardware>
        <xacro:can_joint joint_name="arm_right_wrist_roll_joint" id="26"/>
        <xacro:can_joint joint_name="arm_right_wrist_pitch_joint" id="27"/>
      </ros2_control>
    </xacro:if>

    <!-- ================================================================== -->
    <!-- Mock System: 自动接管所有未启用的真实硬件关节                        -->
    <!-- ================================================================== -->
    <ros2_control name="${name}_mock" type="system">
      <hardware>
        <plugin>mock_components/GenericSystem</plugin>
      </hardware>

      <xacro:macro name="mock_joint" params="joint_name initial_pos:=0.0">
        <joint name="${joint_name}">
          <command_interface name="position"/>
          <state_interface name="position"><param name="initial_value">${initial_pos}</param></state_interface>
          <state_interface name="velocity"/>
        </joint>
      </xacro:macro>

      <!-- 自动分配到 Mock 的关节 -->
      <xacro:unless value="${l_arm_enabled}">
        <xacro:mock_joint joint_name="arm_left_shoulder_pitch_joint"/>
        <xacro:mock_joint joint_name="arm_left_shoulder_roll_joint"/>
        <xacro:mock_joint joint_name="arm_left_shoulder_yaw_joint"/>
        <xacro:mock_joint joint_name="arm_left_elbow_pitch_joint"/>
        <xacro:mock_joint joint_name="arm_left_wrist_yaw_joint"/>
      </xacro:unless>

      <xacro:unless value="${r_arm_enabled}">
        <xacro:mock_joint joint_name="arm_right_shoulder_pitch_joint"/>
        <xacro:mock_joint joint_name="arm_right_shoulder_roll_joint"/>
        <xacro:mock_joint joint_name="arm_right_shoulder_yaw_joint"/>
        <xacro:mock_joint joint_name="arm_right_elbow_pitch_joint"/>
        <xacro:mock_joint joint_name="arm_right_wrist_yaw_joint"/>
      </xacro:unless>

      <xacro:unless value="${l_wrist_enabled}">
        <xacro:mock_joint joint_name="arm_left_wrist_roll_joint"/>
        <xacro:mock_joint joint_name="arm_left_wrist_pitch_joint"/>
      </xacro:unless>

      <xacro:unless value="${r_wrist_enabled}">
        <xacro:mock_joint joint_name="arm_right_wrist_roll_joint"/>
        <xacro:mock_joint joint_name="arm_right_wrist_pitch_joint"/>
      </xacro:unless>

      <!-- 腰部关节始终 Mock -->
      <xacro:mock_joint joint_name="waist_yaw_joint" initial_pos="0.0"/>
      <xacro:mock_joint joint_name="waist_roll_joint" initial_pos="0.0"/>
      <xacro:mock_joint joint_name="waist_pitch_joint" initial_pos="0.0"/>
    </ros2_control>

  </xacro:macro>

</robot>
